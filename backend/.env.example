# =============================================================================
# TEMPLATE ONLY — copy this file to `.env` and fill in YOUR values.
# Never put real passwords or keys in `.env.example` (this file is for git).
# The serious / secret file is `.env` in this same folder (gitignored).
# =============================================================================

# --- PostgreSQL (required for tenant API + seed) ---
# Get it from Supabase: Project Settings → Database → Connection string → URI
#
# 1) Change the scheme for this app:
#    postgres://  or  postgresql://   →   postgresql+psycopg://
#
# 2) If your database password has special characters (@ # % & + : / ? etc.),
#    you MUST URL-encode them in the password part of the URL, e.g. @ → %40
#    (or reset the DB password in Supabase to a simpler one temporarily).
#
# 3) Try these if one fails:
#    • "Direct connection": host db.<project-ref>.supabase.co, port 5432
#    • "Session pooler" (IPv4 / some networks): host aws-0-....pooler.supabase.com, port 6543
#      user is often postgres.<project-ref> — copy exactly from the dashboard.
#
# 4) Optional query (if SSL errors): ?sslmode=require
#
# 5) Do NOT add ?pgbouncer=true for Python/psycopg — that flag is for Prisma only; psycopg errors on it.
#
# Example SHAPE only (not real — replace everything):
# DATABASE_URL=postgresql+psycopg://postgres.xxxxx:ENCODED_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- getaddrinfo failed / Errno 11001 on db.*.supabase.co? ---
# Your network/DNS cannot resolve the direct DB host. Switch DATABASE_URL to the
# “Session pooler” URI from Supabase (different hostname, often pooler.supabase.com:6543),
# then change the scheme to postgresql+psycopg:// — see seed script output for steps.

# --- Optional later (Supabase REST / Auth — not used by current FastAPI DB code) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Explanations (POST /tenants/explanations) ---
# Demo mode (default): realistic fixed text for seeded Casablanca / Aïn Sebaâ applicants — no API call.
# FAKE_GEMINI_EXPLANATIONS=true
#
# Live Gemini: set FAKE_GEMINI_EXPLANATIONS=false and configure:
# GEMINI_API_KEY=
# Optional: GEMINI_MODEL=gemini-2.0-flash (default). One request per Compare; failures → 502.
# Alias: GOOGLE_API_KEY works the same as GEMINI_API_KEY

# --- Legal Advisor — POST /api/legal/* ---
# Default: demo mode (no Anthropic, no python-docx). Conflicts + lease (AR/FR/EN templates) are generated locally.
# FAKE_LEGAL_ADVISOR=true
#
# Live Claude + optional Word export: pip install python-docx, then:
# FAKE_LEGAL_ADVISOR=false
# ANTHROPIC_API_KEY=sk-ant-...
# Optional: ANTHROPIC_MODEL=claude-sonnet-4-20250514 (default)
# Optional landlord placeholders in generated contracts (FR/EN/AR templates):
# LEGAL_LANDLORD_FULL_NAME=أحمد العلوي
# LEGAL_LANDLORD_NAME_LATIN=Ahmed Alaoui
# LEGAL_LANDLORD_CIN=AB123456
# LEGAL_LANDLORD_ADDRESS=...
# LEGAL_LANDLORD_PROFESSION=موظف
#
# If post_visit_forms already existed before contract_language was added, run once:
#   ALTER TABLE post_visit_forms ADD COLUMN IF NOT EXISTS contract_language VARCHAR(8) NOT NULL DEFAULT 'ar';
